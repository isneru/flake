:root, .theme-dark {
  --font-primary: "{{mono}}", "Helvetica Neue", Helvetica, Arial, sans-serif !important;
  --font-display: "{{mono}}", "Helvetica Neue", Helvetica, Arial, sans-serif !important;

  /* New layout system */
  --app-frame-background: {{bgDim}};
  --background-base-lowest: {{bgDim}};
  --background-base-lower: {{bgDim}};
  --background-base-low: {{bg}};
  --background-surface-high: {{bgAlt}};
  --background-surface-higher: {{bgAlt}};
  --background-surface-highest: {{bgAlt}};
  --chat-background: {{bg}};
  --chat-background-default: {{bgAlt}};
  --channel-background-default: {{bgDim}};
  --channeltextarea-background: {{bgAlt}};
  --modal-background: {{bgAlt}};
  --modal-footer-background: {{bgAlt}};
  --card-background-default: {{bgAlt}};
  --home-background: {{bgAlt}};
  --embed-background: {{bgAlt}};
  --embed-background-alternate: {{bg}};
  --background-secondary-alt: {{bgAlt}};

  /* Text */
  --text-default: {{fg}};
  --text-strong: {{fg}};
  --text-subtle: {{fgDim}};
  --text-muted: {{fgMuted}};
  --text-link: {{blue}};
  --text-feedback-positive: {{success}};
  --text-feedback-warning: {{warning}};
  --text-feedback-critical: {{error}};
  --text-feedback-info: {{cyan}};
  --channels-default: {{fgDim}};
  --channel-icon: {{fgMuted}};
  --channel-text-area-placeholder: {{fgMuted}};
  --input-placeholder-text-default: {{fgMuted}};

  /* Interactive */
  --interactive-text-default: {{fgDim}};
  --interactive-text-hover: {{fg}};
  --interactive-text-active: {{fg}};
  --interactive-icon-default: {{fgDim}};
  --interactive-icon-hover: {{fg}};
  --interactive-icon-active: {{fg}};
  --interactive-muted: {{fgMuted}};

  /* Brand / accent */
  --brand-experiment: {{accent}};
  --brand-experiment-300: {{accent}};
  --brand-experiment-330: {{accent}};
  --brand-experiment-360: {{accent}};
  --brand-experiment-400: {{accent}};
  --brand-experiment-430: {{accent}};
  --brand-experiment-460: {{accent}};
  --brand-experiment-500: {{accent}};
  --focus-primary: {{accent}};

  /* Scrollbar */
  --scrollbar-thin-thumb: {{border}};
  --scrollbar-auto-thumb: {{border}};
  --scrollbar-auto-track: {{bgDim}};

  /* Hover/selection modifiers */
  --background-modifier-hover: color-mix(in srgb, {{accent}} 8%, transparent);
  --background-modifier-active: color-mix(in srgb, {{accent}} 16%, transparent);
  --background-modifier-selected: color-mix(in srgb, {{accent}} 24%, transparent);
  --background-modifier-accent: color-mix(in srgb, {{accent}} 12%, transparent);
}
