{
	"layer": "bottom",
	"height": 32,
	"position": "bottom",
	"modules-left": [
		"custom/nixos",
		"niri/workspaces"
	],
	"modules-center": [
		"niri/window"
	],
	"modules-right": [
		"group/tray-expander",
		"group/ctl",
		"clock"
	],
	"niri/workspaces": {
		"all-outputs": false,
		"tooltip": false,
		"format": "{icon}",
		"format-icons": {
			"default": "",
			"active": ""
		},
		"persistent-workspaces": {
			"*": [
				1,
				2,
				3,
				4,
				5
			]
		}
	},
	"custom/nixos": {
		"format": "󱄅"
	},
	"clock": {
		"format": "{:%H:%M}",
		"tooltip-format": "<big>{:%Y %B}</big>\n<tt><small>{calendar}</small></tt>"
	},
	"network": {
		"format-wifi": " ",
		"format-ethernet": "󰈀",
		"format-disconnected": "󰤮",
		"interval": 5,
		"tooltip-format-wifi": "{essid} ({signalStrength}%) ",
		"tooltip-format-ethernet": "{ifname} 󰈀",
		"on-click": "networkmanager_dmenu"
	},
	"group/tray-expander": {
		"orientation": "inherit",
		"drawer": {
			"transition-duration": 600,
			"children-class": "tray-group-item"
		},
		"modules": [
			"custom/expand-icon",
			"tray"
		]
	},
	"custom/expand-icon": {
		"format": "",
		"tooltip": false
	},
	"cpu": {
		"format": "󰍛 {usage}%",
		"tooltip": false
	},
	"memory": {
		"format": "[RAM: {used}GB]",
		"tooltip": false
	},
	"disk": {
		"format": "[DSK: {used}/{total}]",
		"tooltip": false
	},
	"tray": {
		"icon-size": 12,
		"spacing": 4
	},
	"bluetooth": {
		"format": "",
		"format-disabled": "󰂲",
		"format-connected": "󰂱",
		"format-no-controller": "",
		"tooltip-format": "Devices connected: {num_connections}"
	},
	"pulseaudio": {
		"scroll-step": 5,
		"max-volume": 150,
		"format": "{icon}",
		"format-icons": [
			"",
			"",
			" "
		],
		"nospacing": 1,
		"format-muted": " ",
		"on-click": "ghostty --class=audio-mixer -e pulsemixer",
		"tooltip": {
			"format": "Volume: {volume}%\n{if mute}Muted{/if}"
		}
	},
	"niri/window": {
		"format": "{app-name | app-id | title}"
	},
	"custom/separator#blank": {
		"format": " ",
		"interval": "once",
		"tooltip": false
	},
	"group/ctl": {
		"orientation": "inherit",
		"modules": [
			"custom/separator#blank",
			"bluetooth",
			"network",
			"pulseaudio",
			"cpu",
			"battery"
		]
	},
	"battery": {
		"states": {
			"warning": 30,
			"critical": 15
		},
		"format": "{icon} {capacity}%",
		"format-charging": "󰂄 {capacity}%",
		"format-plugged": "󰂄 {capacity}%",
		"format-alt": "{icon} {time}",
		"format-full": "󰁹 {capacity}%",
		"format-icons": [
			"󱊡",
			"󱊢",
			"󱊣"
		]
	}
}
